+// Non-upstream: Simon 1 Traditional Chinese (Big5) CJK font loading.
+void AGOSEngine_Simon1::loadCJKFont() {
+	// Try to auto-detect CJK mode by font file presence
+	Common::File f;
+	if (!f.open("simon_zh16.dcjk")) {
+		if (_language == Common::ZH_TWN) {
+			// User requested Chinese but no font file
+			warning("Simon CHT: simon_zh16.dcjk not found, CJK mode disabled");
+		}
+		return;
+	}
+
+	byte hdr[15];
+	if (f.read(hdr, 15) != 15) {
+		warning("Simon CHT: simon_zh16.dcjk header too short");
+		return;
+	}
+
+	if (hdr[0] != 'D' || hdr[1] != 'C' || hdr[2] != 'J' || hdr[3] != 'K') {
+		warning("Simon CHT: simon_zh16.dcjk invalid magic");
+		return;
+	}
+
+	// Auto-detect: if the font file exists, force ZH_TWN language
+	if (_language != Common::ZH_TWN)
+		_language = Common::ZH_TWN;
+
+	_cjkFontW = hdr[5];
+	_cjkFontH = hdr[6];
+	_cjkFontBpr = hdr[7];
+	uint32 numGlyphs = READ_LE_UINT32(hdr + 11);
+
+	uint32 dataSize = (uint32)_cjkFontBpr * _cjkFontH * numGlyphs;
+	_cjkFontData = new byte[dataSize];
+	if (f.read(_cjkFontData, dataSize) != dataSize) {
+		delete[] _cjkFontData;
+		_cjkFontData = nullptr;
+		warning("Simon CHT: simon_zh16.dcjk data read failed");
+		return;
+	}
+	f.close();
+
+	_chtCJKMode = true;
+	_subtitles = true;
+	_speech = false;
+	ConfMan.setBool("subtitles", true);
+	ConfMan.setBool("speech_mute", false);
+
+	warning("Simon CHT: CJK font loaded (%dx%d, %u glyphs)", _cjkFontW, _cjkFontH, numGlyphs);
+}
+
+// Non-upstream: Simon 1 Traditional Chinese translation table loading.
+void AGOSEngine_Simon1::loadCHTTable() {
+	if (!_chtCJKMode)
+		return;
+
+	Common::File f;
+	if (!f.open("simon_zh.tab"))
+		return;
+
+	int32 size = f.size();
+	if (size <= 0 || size > 65536)
+		return;
+
+	byte *buf = new byte[size + 1];
+	uint32 readSize = f.read(buf, (uint32)size);
+	if ((int32)readSize != size) {
+		delete[] buf;
+		return;
+	}
+	f.close();
+	buf[size] = 0;
+
+	int count = CHT::loadTable(buf, (uint32)size);
+	debug("Simon CHT table loaded: %d entries", count);
+
+	delete[] buf;
+	CHT::dumpInit();
+}
+
 } // End of namespace AGOS
