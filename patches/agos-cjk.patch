+// Non-upstream: Simon 1 Traditional Chinese (Big5) CJK window text rendering.
+void AGOSEngine_Simon1::windowDrawChar(WindowBlock *window, uint x, uint y, byte chr) {
+	if (!_chtCJKMode || _forceAscii || !_cjkFontData) {
+		AGOSEngine::windowDrawChar(window, x, y, chr);
+		return;
+	}
+
+	_videoLockOut |= 0x8000;
+
+	// Assemble Big5 double-byte character
+	bool isDoubleByte = false;
+	byte lead = 0, trail = 0;
+
+	if (_cjkCurChar != 0) {
+		// We have a pending lead byte, this is the trail
+		lead = (byte)_cjkCurChar;
+		trail = chr;
+		isDoubleByte = true;
+		_cjkCurChar = 0;
+	} else if (CHT::isBig5Lead(chr)) {
+		// Start of a Big5 pair - store lead and wait
+		_cjkCurChar = chr;
+		_videoLockOut &= ~0x8000;
+		return;
+	}
+	// else: single-byte ASCII char, handled below
+
+	int glyphIdx = -1;
+	if (isDoubleByte) {
+		glyphIdx = CHT::big5LinearIndex(lead, trail);
+	} else {
+		// Single byte ASCII: use direct mapping (char 32 = index 0)
+		glyphIdx = -1; // Will fall through to ASCII fallback
+	}
+
+	uint fw = _cjkFontW;
+	uint fh = _cjkFontH;
+	uint fbpr = _cjkFontBpr;
+
+	Graphics::Surface *screen = getBackendSurface();
+	if (!screen) {
+		_videoLockOut &= ~0x8000;
+		return;
+	}
+
+	byte *dstBase = (byte *)screen->getPixels();
+	uint dstPitch = screen->pitch;
+
+	// Clip to screen bounds
+	int sx = (int)x;
+	int sy = (int)y;
+	if (sx < 0 || sy < 0 || sx + (int)fw > screen->w || sy + (int)fh > screen->h) {
+		_videoLockOut &= ~0x8000;
+		return;
+	}
+
+	dstBase += sy * dstPitch + sx;
+	byte color = window->textColor;
+
+	if (glyphIdx >= 0 && _cjkFontData) {
+		// Render from CJK font bitmap (1bpp, MSB-first per row)
+		const byte *glyph = _cjkFontData + (uint32)glyphIdx * fbpr * fh;
+		for (uint row = 0; row < fh; row++) {
+			byte *dst = dstBase + row * dstPitch;
+			const byte *src = glyph + row * fbpr;
+			for (uint ci = 0; ci < fw; ci++) {
+				if (src[ci >> 3] & (0x80 >> (ci & 7)))
+					dst[ci] = color;
+			}
+		}
+	} else if (!isDoubleByte && chr >= 32 && chr < 128) {
+		// Fallback: render ASCII char with base class style (8x6)
+		// Centered vertically in the CJK cell
+		uint offY = (fh > 8) ? (fh - 8) / 2 : 0;
+		const byte *asciiSrc = english_simonFont + (chr - 32) * 8;
+		for (uint row = 0; row < 8; row++) {
+			byte *dst = dstBase + (offY + row) * dstPitch;
+			byte b = asciiSrc[row];
+			for (uint ci = 0; ci < 6; ci++) {
+				if (b & (0x80 >> ci))
+					dst[ci] = color;
+			}
+		}
+	}
+
+	Common::Rect dirtyRect(sx, sy, sx + (int)fw, sy + (int)fh);
+	updateBackendSurface(&dirtyRect);
+
+	_videoLockOut &= ~0x8000;
+}
